# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
#
# Public values — safe to expose (used by the test script + frontend in vaja9):
SUPABASE_URL=https://iemafnwkncyzlxoqyuzm.supabase.co
# Publishable key (sb_publishable_...) — the client-side `apikey`.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# SECRET key (sb_secret_...) — bypasses RLS. Optional locally: deployed
# functions get it auto-injected. Never commit the real value.
SUPABASE_SECRET_KEY=sb_secret_...

# Cloud Postgres password (the one set when creating the project).
DB_PASS=changeme

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.iemafnwkncyzlxoqyuzm:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres"